{
  "name": "teslacam-recovery",
  "version": "0.0.3",
  "description": "Tesla dashcam video recovery — scans USB drives directly",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:icon": "node -e \"const sharp=require('sharp'),fs=require('fs');sharp(fs.readFileSync('build/icon.svg'),{density:300}).resize(1024,1024).png().toFile('build/icon.png').then(()=>console.log('done')).catch(e=>{console.error(e);process.exit(1)})\"",
    "lint": "eslint .",
    "test": "jest"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jest": "^29.0.0",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.teslacam.recovery",
    "productName": "TeslaCam Recovery",
    "files": [
      "main.js",
      "preload.js",
      "worker.js",
      "index.html",
      "lib/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": {
        "teamId": "QK69VT259D"
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis"
        }
      ],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage"
        }
      ],
      "category": "Utility"
    }
  }
}
